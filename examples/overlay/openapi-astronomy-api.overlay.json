{
  "$schema": "https://open-resource-discovery.org/spec-extension/models/OrdOverlay.schema.json#",
  "ordOverlay": "0.1",
  "ordId": "sap.foo:overlay:astronomy-api-openapi:v1",
  "description": "Adds deprecation notices and supplementary documentation to the Astronomy REST API without modifying the original OpenAPI specification.\n\nThe first patch uses the 'operation' concept-level selector, which maps to the OpenAPI 'operationId' field.",
  "describedSystemType": {
    "systemNamespace": "sap.foo"
  },
  "visibility": "internal",
  "target": {
    "ordId": "sap.foo:apiResource:astronomy:v1",
    "url": "/ord/metadata/astronomy-v1.oas3.json",
    "definitionType": "openapi-v3"
  },
  "meta": {
    "sourceSystem": "AI Enrichment Pipeline v2.1",
    "enrichmentDate": "2025-04-01"
  },
  "patches": [
    {
      "description": "Add OAuth2 security scheme and update API contact info at the document root.",
      "action": "merge",
      "selector": {
        "root": true
      },
      "data": {
        "info": {
          "contact": {
            "name": "Astronomy API Support",
            "email": "astronomy-api@example.com"
          }
        },
        "components": {
          "securitySchemes": {
            "OAuth2": {
              "type": "oauth2",
              "flows": {
                "clientCredentials": {
                  "tokenUrl": "https://auth.example.com/oauth/token",
                  "scopes": {
                    "astronomy:read": "Read access to astronomy data"
                  }
                }
              }
            }
          }
        }
      }
    },
    {
      "action": "merge",
      "selector": {
        "operation": "getConstellationByAbbreviation"
      },
      "data": {
        "deprecated": true,
        "x-deprecation-notice": "Use getConstellationByIAUCode instead. This operation will be removed in v2."
      }
    },
    {
      "action": "merge",
      "selector": {
        "jsonPath": "$.components.schemas.Star.properties.magnitude"
      },
      "data": {
        "description": "Apparent magnitude of the star as observed from Earth. Lower values indicate greater brightness (e.g. the Sun is -26.7).",
        "x-sap-visibility": "public"
      }
    },
    {
      "action": "merge",
      "selector": {
        "jsonPath": "$.components.schemas.Constellation"
      },
      "data": {
        "externalDocs": {
          "description": "IAU constellation reference catalogue",
          "url": "https://www.iau.org/public/themes/constellations/"
        }
      }
    }
  ]
}
