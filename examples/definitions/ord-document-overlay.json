{
  "$schema": "https://open-resource-discovery.org/spec-v1/interfaces/OrdOverlay.schema.json#",
  "ordOverlay": "0.1",
  "ordId": "sap.platform:overlay:ord-reference-app-enrichment:v1",
  "description": "Assigns ORD resources from the reference app to platform groups and adds platform-managed labels, without modifying the original ORD document. Note: a dedicated ordId selector for ORD document-level patching is planned for a future version.",
  "target": {
    "ordId": "sap.foo:package:ord-reference-app:v0",
    "url": "/open-resource-discovery/v1/documents/example"
  },
  "patches": [
    {
      "action": "merge",
      "selector": {
        "jsonPath": "$.apiResources[?(@.ordId=='sap.foo:apiResource:astronomy:v1')]"
      },
      "data": {
        "partOfGroups": [
          "sap.platform:domainGroup:sap.platform:scienceApis"
        ],
        "labels": {
          "platform-tier": ["gold"],
          "data-classification": ["public"]
        },
        "tags": ["astronomy", "reference"]
      }
    },
    {
      "action": "merge",
      "selector": {
        "jsonPath": "$.eventResources[?(@.ordId=='sap.foo:eventResource:ExampleEventResource:v1')]"
      },
      "data": {
        "partOfGroups": [
          "sap.platform:domainGroup:sap.platform:scienceApis"
        ],
        "labels": {
          "platform-tier": ["silver"]
        }
      }
    },
    {
      "action": "merge",
      "selector": {
        "jsonPath": "$.packages[?(@.ordId=='sap.foo:package:ord-reference-app:v0')]"
      },
      "data": {
        "labels": {
          "managed-by": ["platform-team"]
        }
      }
    }
  ]
}
